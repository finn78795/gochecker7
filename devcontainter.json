{
    "name": "Snapchat-VNC-Experiment",
    "image": "mcr.microsoft.com/devcontainers/universal:2",
    "features": {
        "ghcr.io/devcontainers/features/desktop-lite:1": {
            "password": "vscode"
        }
    },
    "forwardPorts": [6080],
    "portsAttributes": {
        "6080": {
            "label": "Desktop View",
            "onAutoForward": "openBrowser"
        }
    },
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y chromium-browser"
}
